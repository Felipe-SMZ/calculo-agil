<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060D6A"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="Calculadora de Velocidade"
        android:textColor="#F4F3F3"
        android:textSize="24sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editDistancia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Distância (metros)"
        android:inputType="numberDecimal"
        android:textAlignment="center"
        android:textColor="#F4F3F3"
        android:textColorHint="#F0ECEC" />

    <EditText
        android:id="@+id/editTempo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:hint="Tempo (segundos)"
        android:inputType="numberDecimal"
        android:textAlignment="center"
        android:textColor="#F4F3F3"
        android:textColorHint="#F0ECEC" />

    <Button
        android:id="@+id/btnCalcular"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#00C853"
        android:text="CALCULAR"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtResultado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resultado: -"
        android:textColor="#F8F4F4"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#00C853"
        android:text="Voltar"
        android:textColor="@color/white" />

</LinearLayout>